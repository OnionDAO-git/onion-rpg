{
	"name": "onion-rpg",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"start": "node build",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"orpg:bundle": "node scripts/bundle-orpg.js --screens all --out oRPG/dist/oRPG.bundle.lua",
		"orpg:bundle:per-screen": "node scripts/bundle-orpg.js --per-screen",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"db:init": "bun scripts/db-init.ts",
		"kanban:seed": "bun scripts/db-kanban-seed.ts",
		"beacon:flash:config": "bash beacon/scripts/flash_spiffs.sh",
		"test": "bun test"
	},
	"devDependencies": {
		"mermaid": "^11.4.0",
		"@sveltejs/adapter-node": "^5.3.1",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"@types/bun": "^1.3.14",
		"@types/node": "^25.2.2",
		"svelte": "^5.49.2",
		"svelte-check": "^4.3.6",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.71.0",
		"@solana/spl-token": "^0.4.14",
		"@solana/web3.js": "^1.98.4",
		"postgres": "^3.4.8"
	}
}
