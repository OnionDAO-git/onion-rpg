# ===== ONION RPG game server =====
# Copy to .env and fill in. Mirrors landing-2026 style (postgres + dynamic env).

# --- Database ---
# Postgres connection string for the oRPG game database (separate from the
# landing-2026 DB). Local docker default suggestion below.
DATABASE_URL=postgresql://orpg:orpg_dev@localhost:5432/orpg

# --- Onion DAO API (the real currency + registry server, landing-2026) ---
# The oRPG server is an EXTERNAL APP to this API.
ONION_API_BASE_URL=https://oniondao.dev
# Bearer key issued to this external app for POST /api/public/onions/requests.
ONION_EXTERNAL_API_KEY=
# Identifier this app sends as `requester` (scopes idempotency keys).
ONION_REQUESTER_ID=onion-rpg
# Shared secret we attach as callbackSecret so we can verify HMAC callbacks.
ONION_CALLBACK_SECRET=
# Public URL the Onion API can POST reward callbacks back to.
ONION_CALLBACK_URL=https://rpg.oniondao.dev/api/onion/callback

# --- Anthropic / DEEPDISH Storyteller ---
ANTHROPIC_API_KEY=
# Model for finale/high-stakes beats (Act 4, twist reveal).
STORYTELLER_MODEL_FINALE=claude-opus-4-8
# Model for routine NPC dialogue (Acts 0-3).
STORYTELLER_MODEL_DIALOGUE=claude-sonnet-4-6

# --- Speech-to-text (pluggable) ---
# Provider key: 'whisper-http' (default), 'mock' (dev), or custom.
STT_PROVIDER=whisper-http
# Endpoint for an OpenAI-Whisper-compatible STT server.
STT_ENDPOINT=
STT_API_KEY=
# Whisper model name sent to the endpoint (default: whisper-1).
STT_MODEL=whisper-1
# Used by the 'mock' provider to inject a fixed transcript for dev/tests.
STT_MOCK_TRANSCRIPT=

# --- Beacon <-> server bridge auth ---
# Beacons authenticate to the badge/beacon-facing API with this bearer key.
BEACON_API_KEY=

# --- Solana (future on-chain item/credential backing; not required now) ---
SOLANA_RPC_URL=
